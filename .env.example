# When using MSW mocks, leave VITE_API_BASE_URL empty so requests stay same-origin
# (service worker can only intercept same-origin requests)
VITE_API_BASE_URL=
VITE_USE_MOCK_API=false

# When connecting to real backend, set the full URL and disable mocks
# VITE_API_BASE_URL=http://localhost:3000
# VITE_USE_MOCK_API=false
